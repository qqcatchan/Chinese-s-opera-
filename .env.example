# .env.example

# Domain for TLS and public access
DOMAIN=https://github.com/chanqueenieolivia-ui/Chinese-s-opera-/pull/6/files

# TURN server: long-term credential secret (generate with openssl rand -hex 32)
TURN_SECRET=replace_with_random_secret

# Public IP of the server (for coturn external-ip)
COTURN_EXTERNAL_IP=203.0.113.10

# Signaling server port
SIGNALING_PORT=4000

